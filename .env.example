# ── Django API ───────────────────────────────────────────────────────────────
# Generate a strong key: python -c "import secrets; print(secrets.token_urlsafe(50))"
SECRET_KEY=change-me-in-production

# Set to False in production
DEBUG=False

# Comma-separated list of allowed hostnames (your domain + www)
DJANGO_ALLOWED_HOSTS=yourdomain.fr,www.yourdomain.fr

# SQLite path (persistent volume) — set in production to /app/data/db.sqlite3
DB_PATH=/app/data/db.sqlite3

# Comma-separated CORS origins allowed to call the API (only needed when DEBUG=False)
CORS_ALLOWED_ORIGINS=https://yourdomain.fr,https://www.yourdomain.fr
